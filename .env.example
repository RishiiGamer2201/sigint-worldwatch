# ─────────────────────────────────────────────────────────────
#  SIGINT WorldWatch — Environment Variables
#  Copy this file to .env and fill in your keys
# ─────────────────────────────────────────────────────────────

# Server port (default: 3001)
PORT=3001

# ── NEWS APIs (for richer coverage) ─────────────────────────
# NewsAPI — Free 100 req/day: https://newsapi.org/register
NEWS_API_KEY=

# Mediastack — Free 500 req/month: https://mediastack.com
MEDIASTACK_KEY=

# ── AI APIs for the Chatbot (pick at least one) ──────────────
# GROQ — FREE, very fast LLaMA models: https://console.groq.com
# RECOMMENDED: Free tier is generous, llama-3.3-70b is excellent
GROQ_API_KEY=

# Anthropic Claude — Haiku is very affordable: https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI — GPT-4o-mini is cheap: https://platform.openai.com
OPENAI_API_KEY=

# OpenRouter — Access many free models: https://openrouter.ai
OPENROUTER_KEY=
